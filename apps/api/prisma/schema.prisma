generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BusinessType {
  RESTAURANT
  FOOD_TRUCK
  SERVICE
  CONSULTANT
  MEDICAL
  RETAIL
  OTHER
}

enum Plan {
  FREE
  PRO
  BUSINESS
  SCALE
}

enum FlowType {
  ORDER
  MEETING
  INQUIRY
  CUSTOM
  FALLBACK
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum UsageType {
  SMS_SENT
  AI_CALL
  CALL_WEBHOOK
  SQUARE_ORDER
  POS_ORDER
}

enum ConsentStatus {
  PENDING
  CONSENTED
  DECLINED
  EXPIRED
}

enum PosProviderType {
  square
  clover
  toast
  shopify
}

enum HandoffStatus {
  AI
  HUMAN
}

enum ContactStatus {
  LEAD
  CUSTOMER
  VIP
  INACTIVE
}

enum CommissionStatus {
  PENDING
  PAID
  VOID
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum AgencyApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tenant {
  id                    String           @id @default(uuid())
  name                  String
  slug                  String?          @unique // URL-safe public identifier for menu page (ringbacksms.com/m/{slug})
  businessType          BusinessType
  plan                  Plan             @default(FREE)
  twilioSubAccountSid   String?          @unique
  twilioAuthToken       String? // AES-256-GCM encrypted
  twilioPhoneNumber     String?          @unique
  twilioPhoneNumberSid  String?          @unique
  stripeCustomerId      String?          @unique
  stripeSubscriptionId  String?          @unique
  clerkOrgId            String?          @unique
  squareAccessToken     String? // AES-256-GCM encrypted
  squareRefreshToken    String? // AES-256-GCM encrypted
  squareLocationId      String?
  squareMerchantId      String?
  squareTokenExpiresAt  DateTime?
  // Provider-agnostic POS fields
  posProvider           PosProviderType?
  posAccessToken        String? // AES-256-GCM encrypted
  posRefreshToken       String? // AES-256-GCM encrypted
  posTokenExpiresAt     DateTime?
  posLocationId         String?
  posMerchantId         String?
  posRaw                Json? // provider-specific metadata
  isActive              Boolean          @default(true)
  agencyId              String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  agency             Agency?             @relation(fields: [agencyId], references: [id])
  config             TenantConfig?
  flows              Flow[]
  missedCalls        MissedCall[]
  conversations      Conversation[]
  orders             Order[]
  meetings           Meeting[]
  menuItems          MenuItem[]
  menuCategories     MenuCategory[]
  usageLogs          UsageLog[]
  contacts           Contact[]
  syncLogs           PosSyncLog[]
  replyTemplates     ReplyTemplate[]
  tasks              Task[]
  foodTruckStops     FoodTruckStop[]
  smsConsentRequests SmsConsentRequest[]
  smsSuppressions    SmsSuppression[]
  escalationEvents   EscalationEvent[]
  commissions        CommissionLedger[]
  members            TenantMember[]
  smsCampaigns       SmsCampaign[]
  locations          TenantLocation[]
  devices            Device[]
  devicePairingCodes DevicePairingCode[]
  turns              Turn[]
  calendarBlackouts  CalendarBlackout[]

  @@index([twilioPhoneNumber])
  @@index([clerkOrgId])
  @@index([agencyId])
}

model Agency {
  id                     String   @id @default(uuid())
  clerkUserId            String   @unique
  name                   String?
  defaultRevSharePct     Decimal  @default(20) @db.Decimal(5, 2)
  stripeConnectAccountId String?  @unique
  stripeConnectOnboarded Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenants     Tenant[]
  commissions CommissionLedger[]
  payouts     Payout[]
}

model CommissionLedger {
  id                    String           @id @default(uuid())
  agencyId              String
  tenantId              String
  stripeInvoiceId       String           @unique
  invoiceAmountCents    Int
  commissionPct         Decimal          @db.Decimal(5, 2)
  commissionAmountCents Int
  currency              String           @default("usd")
  status                CommissionStatus @default(PENDING)
  payoutId              String?
  accruedAt             DateTime         @default(now())
  paidAt                DateTime?

  agency Agency  @relation(fields: [agencyId], references: [id])
  tenant Tenant  @relation(fields: [tenantId], references: [id])
  payout Payout? @relation(fields: [payoutId], references: [id])

  @@index([agencyId, status])
  @@index([tenantId])
}

model Payout {
  id               String       @id @default(uuid())
  agencyId         String
  amountCents      Int
  currency         String       @default("usd")
  stripeTransferId String?      @unique
  status           PayoutStatus @default(PENDING)
  periodStart      DateTime
  periodEnd        DateTime
  failureReason    String?
  createdAt        DateTime     @default(now())
  paidAt           DateTime?

  agency      Agency             @relation(fields: [agencyId], references: [id])
  commissions CommissionLedger[]

  @@index([agencyId, status])
}

model AgencyApplication {
  id          String                  @id @default(uuid())
  clerkUserId String                  @unique
  email       String
  fullName    String
  companyName String?
  website     String?
  pitch       String                  @db.Text
  status      AgencyApplicationStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?                 @db.Text
  createdAt   DateTime                @default(now())

  @@index([status])
}

model FoodTruckStop {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stopDate     DateTime @db.Date
  locationName String?
  address      String
  openTime     String // "HH:mm" 24h, tenant-local
  closeTime    String // "HH:mm" 24h, tenant-local
  note         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, stopDate])
  @@index([tenantId, isActive, stopDate])
}

model TenantConfig {
  id                             String    @id @default(uuid())
  tenantId                       String    @unique
  tenant                         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  greeting                       String    @db.Text
  greetingAfterHours             String?   @db.Text
  greetingRapidRedial            String?   @db.Text
  greetingReturning              String?   @db.Text
  voiceGreeting                  String?   @db.Text
  voiceGreetingAfterHours        String?   @db.Text
  voiceGreetingRapidRedial       String?   @db.Text
  voiceGreetingReturning         String?   @db.Text
  voiceAudioUrl                  String?   // public URL for default greeting audio
  voiceAudioUrlAfterHours        String?   // public URL for after-hours greeting audio
  voiceAudioUrlRapidRedial       String?   // public URL for rapid-redial greeting audio
  voiceAudioUrlReturning         String?   // public URL for returning greeting audio
  voiceType                      String    @default("nova")
  timezone                       String    @default("America/Chicago")
  businessHoursStart             String    @default("11:00")
  businessHoursEnd               String    @default("20:00")
  businessDays                   Int[]
  businessSchedule               Json? // per-day hours: { "0": { "open": "11:00", "close": "19:30" }, ... }
  closedDates                    String[]  @default([]) // ISO date strings: ["2026-12-25"]
  aiPersonality                  String?   @db.Text
  calcomLink                     String?
  slackWebhook                   String?
  ownerEmail                     String?
  ownerPhone                     String?
  businessAddress                String?
  websiteUrl                     String?
  websiteContext                 String?   @db.Text // AI-extracted business context from website
  squareSyncEnabled              Boolean   @default(false)
  squareAutoSync                 Boolean   @default(false)
  posSyncEnabled                 Boolean   @default(false)
  posAutoSync                    Boolean   @default(false)
  requirePayment                 Boolean   @default(false)
  dashboardConfirmTaskCompletion Boolean   @default(true)
  dailyDigestEnabled             Boolean   @default(true)
  dailyDigestHour                Int       @default(8)
  /// Last tenant-local date (YYYY-MM-DD) on which the daily recap was
  /// successfully sent. Idempotency guard for the hourly recap cron —
  /// prevents Vercel cron retries / clock skew from double-sending.
  dailyRecapLastSentDate         String?
  /// Per-tenant kill switch for the Twilio Lookup spam classifier.
  /// Off when tenants get many legitimate VoIP calls (e.g. contractors)
  /// that would otherwise be blocked by the unbranded-VoIP heuristic.
  spamFilterEnabled              Boolean   @default(true)
  // Prep time (restaurants & food trucks)
  defaultPrepTimeMinutes         Int? // null = feature unused
  largeOrderThresholdItems       Int? // null = no large-order rule
  largeOrderExtraMinutes         Int? // null = no large-order rule
  prepTimeOverrides              Json? // Array<{ dayOfWeek, start, end, extraMinutes, label? }>
  ordersAcceptingEnabled         Boolean   @default(true)
  aiOrderAgentEnabled            Boolean   @default(false) // per-tenant rollout of the AI-native ORDER flow (items 1-7)
  acceptClosedHourOrders         Boolean   @default(true)  // when true, bot schedules orders for next open slot even when currently closed
  minutesPerQueuedOrder          Int       @default(4)     // added to ETA for every order currently CONFIRMED or PREPARING
  salesTaxRate                   Decimal?  @db.Decimal(5, 4) // e.g. 0.0825 for 8.25%. Null = no tax applied.
  passStripeFeesToCustomer       Boolean   @default(false) // when true, add 2.9% + $0.30 processing fee as a line item on the checkout
  // Google Business Profile review nudge. When set, customers who reply
  // 4–5 stars to the review prompt receive a follow-up SMS with this link
  // asking them to leave a public review. Unhappy raters (1–3) never see
  // it — protects the public profile from low ratings.
  googleReviewUrl                String?
  // Built-in calendar (used when cal.com isn't configured)
  meetingEnabled                 Boolean   @default(true) // master on/off for built-in calendar
  meetingDurationMinutes         Int       @default(30)
  meetingBufferMinutes           Int       @default(15)
  meetingLeadTimeMinutes         Int       @default(60)  // earliest a slot can be from now()
  meetingMaxDaysOut              Int       @default(30)  // furthest day-out a caller can request
  // cal.com integration (OAuth 2.0 authorization code)
  calcomAccessToken              String? // AES-256-GCM encrypted
  calcomRefreshToken             String? // AES-256-GCM encrypted
  calcomTokenExpiresAt           DateTime?
  calcomUserId                   Int?
  calcomUserEmail                String?
  calcomEventTypeId              Int?
  calcomEventTypeSlug            String?
  // Industry template + consent
  industryTemplateKey            String?
  consentMessage                 String?   @db.Text
  followupOpener                 String?   @db.Text
  customAiInstructions           String?   @db.Text
  customEscalationKeywords       String[]  @default([])
  lastOrdersGraceMinutes         Int       @default(15) // minutes before close after which we refuse new pickups
  cloudPrntToken                 String?   // tenant-unique token a Star CloudPRNT printer polls our endpoint with
  // White-label — applied on /m /o /r /pay public pages
  brandColor                     String?   // hex like "#E03A2F"; null = default blue
  brandLogoUrl                   String?
  hidePoweredBy                  Boolean   @default(false) // premium tier removes the RingbackSMS attribution
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
}

model Flow {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      FlowType
  isEnabled Boolean  @default(true)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type])
  @@index([tenantId, isEnabled])
}

model MissedCall {
  id                  String    @id @default(uuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone         String
  twilioCallSid       String    @unique
  occurredAt          DateTime
  smsSent             Boolean   @default(false)
  voicemailUrl        String?
  voicemailDuration   Int?
  voicemailReceivedAt DateTime?
  voicemailTranscript String?   @db.Text
  voicemailSummary    String?   @db.Text
  voicemailIntent     String?
  voicemailHandledAt  DateTime?
  transcriptionStatus String?
  firstReplyAt        DateTime?
  ownerRespondedAt    DateTime?
  contactId           String?
  contact             Contact?  @relation(fields: [contactId], references: [id])
  callerTier          String?
  createdAt           DateTime  @default(now())

  conversations Conversation[]

  @@index([tenantId, callerPhone])
  @@index([tenantId, occurredAt])
  @@index([contactId])
}

model Conversation {
  id            String        @id @default(uuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone   String
  missedCallId  String?
  missedCall    MissedCall?   @relation(fields: [missedCallId], references: [id])
  messages      Json          @default("[]")
  flowType      FlowType?
  handoffStatus HandoffStatus @default(AI)
  handoffAt     DateTime?
  isActive      Boolean       @default(true)
  /// Turn that most recently touched this Conversation's state. Nullable,
  /// no FK (business data must outlive Turn retention).
  causingTurnId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orders   Order[]
  meetings Meeting[]

  @@index([tenantId, callerPhone])
  @@index([tenantId, isActive])
}

model Order {
  id                 String       @id @default(uuid())
  tenantId           String
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId     String
  conversation       Conversation @relation(fields: [conversationId], references: [id])
  callerPhone        String
  customerName       String?
  orderNumber        String       @unique
  status             OrderStatus  @default(PENDING)
  items              Json
  subtotal           Decimal?     @db.Decimal(10, 2) // items-only subtotal before tax/fee
  taxAmount          Decimal?     @db.Decimal(10, 2) // sales tax applied
  feeAmount          Decimal?     @db.Decimal(10, 2) // processing fee passed to customer (if enabled)
  tipAmount          Decimal?     @db.Decimal(10, 2) // customer-selected tip at checkout
  total              Decimal      @db.Decimal(10, 2) // final amount customer pays (subtotal + tax + fee + tip)
  pickupTime         String?
  /// True when the customer requested dine-in. pickupTime then carries the
  /// customer's *arrival ETA*, not pickup time. Default false for the
  /// dominant pickup case so existing rows backfill correctly.
  dineIn             Boolean      @default(false)
  estimatedReadyTime DateTime?
  notes              String?      @db.Text
  squareOrderId      String?
  squarePaymentId    String?
  posOrderId         String?
  posPaymentId       String?
  stripePaymentId    String?
  stripeRefundId     String?
  stripePaymentUrl   String?
  paymentStatus      String?      @default("UNPAID")
  printedAt          DateTime?    // set by the CloudPRNT POST callback after a successful print
  locationId         String?      // TenantLocation.id — nullable until multi-location is fully wired
  /// Inbound Turn that caused this order to be created. Nullable, no FK —
  /// orders must not cascade-delete when Turn rows are aged out.
  causingTurnId      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, callerPhone])
}

/// Per-tenant role for a Clerk user. Clerk provides one `orgRole`
/// (admin / basic_member) but our operators need finer-grained roles
/// (owner vs kitchen vs viewer) and we want them scoped per tenant, not
/// per Clerk org. When no row exists for a given (tenant, user), the
/// fallback assumes OWNER for Clerk org admins and MEMBER for basic
/// members — keeps existing users unblocked when we ship this.
model TenantMember {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clerkUserId String
  role        TenantMemberRole @default(MEMBER)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, clerkUserId])
  @@index([clerkUserId])
}

enum TenantMemberRole {
  OWNER
  MANAGER
  KITCHEN
  VIEWER
  MEMBER
}

/// Short-lived code a manager generates from the web dashboard to pair a
/// mobile device. Consumed by POST /api/devices/claim which mints a Device
/// and marks the code consumed.
model DevicePairingCode {
  id          String    @id @default(uuid())
  code        String    @unique
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clerkUserId String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([expiresAt])
}

/// A paired mobile device. The bearer token is stored hashed (SHA-256);
/// revocation sets revokedAt and takes effect on the next request since
/// Express middleware hits this table on every authenticated call.
model Device {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clerkUserId String
  label       String
  platform    String
  tokenHash   String    @unique
  fcmToken    String?
  lastSeenAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([clerkUserId])
  @@index([tokenHash])
}

/// Physical location / storefront under a tenant. For v1 every tenant
/// gets exactly one Location row (backfilled from existing Tenant data)
/// and the rest of the system ignores it. Sets the groundwork for
/// operators like McInasal (two trucks, one login) without disturbing
/// current single-location flows.
model TenantLocation {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String   // "Food truck A", "Uptown", etc.
  address          String?
  phone            String?
  squareLocationId String?
  timezone         String?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, isActive])
}

/// Outbound SMS marketing campaign. We queue recipients in a separate
/// table so opt-outs that arrive after queue-time are honored at send.
model SmsCampaign {
  id            String                 @id @default(uuid())
  tenantId      String
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  body          String                 @db.Text
  status        SmsCampaignStatus      @default(DRAFT)
  scheduledFor  DateTime?
  sentAt        DateTime?
  sentCount     Int                    @default(0)
  suppressedCount Int                  @default(0)
  failedCount   Int                    @default(0)
  createdBy     String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  recipients    SmsCampaignRecipient[]

  @@index([tenantId, status])
}

enum SmsCampaignStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
  CANCELLED
}

model SmsCampaignRecipient {
  id           String      @id @default(uuid())
  campaignId   String
  campaign     SmsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId    String?
  phone        String
  status       String      @default("PENDING") // PENDING | SENT | SUPPRESSED | FAILED
  error        String?
  sentAt       DateTime?
  createdAt    DateTime    @default(now())

  @@unique([campaignId, phone])
  @@index([campaignId, status])
}

/// Customer-authored recurring order. A lightweight scheduled-job table —
/// the daily cron picks rows where `nextRunAt <= now AND active=true`,
/// creates a fresh Order from `itemsJson`, and SMS-confirms the customer
/// 1 hour before the scheduled pickup. Customer can reply STOP to set
/// active=false (handled by the suppression + an operator UI later).
model RecurringOrder {
  id          String   @id @default(uuid())
  tenantId    String
  callerPhone String
  label       String?  // "Friday lunch usual"
  cadence     String   // cron-style: "0 12 * * 5" or a friendly like "every Friday 12:00"
  itemsJson   Json
  pickupTime  String?  // "12:00 PM"
  nextRunAt   DateTime
  lastRunAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, active, nextRunAt])
  @@index([callerPhone])
}

/// Post-pickup review. SMS ends after order goes COMPLETED; customer
/// replies 1-5 and we persist a row. One review per order.
model OrderReview {
  id        String   @id @default(uuid())
  orderId   String   @unique
  tenantId  String
  rating    Int      // 1..5
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model Meeting {
  id               String        @id @default(uuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId   String
  conversation     Conversation  @relation(fields: [conversationId], references: [id])
  callerPhone      String
  calcomBookingId  String?
  calcomBookingUid String?
  scheduledAt      DateTime?
  durationMinutes  Int?          // populated for built-in bookings; null for legacy/cal.com rows
  guestName        String?
  guestEmail       String?
  status           MeetingStatus @default(PENDING)
  notes            String?       @db.Text
  /// Timestamp when the day-before confirmation SMS was sent. NULL until
  /// the cron picks the meeting up. Once set, the cron skips it on
  /// future ticks so we never double-send a confirmation.
  confirmationSentAt DateTime?
  /// Set when the caller replies "C" / "yes" / etc. to the confirmation
  /// SMS. Operators see "confirmed" status in the dashboard so they
  /// know which appointments are truly locked in.
  confirmedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, callerPhone])
  @@index([tenantId, scheduledAt])
}

/// Manual block-out windows on the built-in calendar (holidays, team
/// off-sites, owner-only days). Slot generation in localAvailability
/// rejects any candidate slot that overlaps a blackout.
model CalendarBlackout {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  label     String?
  createdAt DateTime @default(now())

  @@index([tenantId, startAt, endAt])
}

model MenuItem {
  id                String    @id @default(uuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  description       String?   @db.Text
  price             Decimal   @db.Decimal(10, 2)
  category          String?               // kept for back-compat with POS sync (Square pushes strings)
  categoryId        String?               // preferred: FK to MenuCategory
  categoryRef       MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  imageUrl          String?
  isAvailable       Boolean   @default(true)
  duration          Int?
  requiresBooking   Boolean   @default(false)
  squareCatalogId   String?
  squareVariationId String?
  lastSyncedAt      DateTime?
  posCatalogId      String?
  posVariationId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  /// Set when a sync detects the item is no longer in the POS catalog.
  /// Operator-visible tombstone — item hidden from the dashboard by
  /// default but we don't hard-delete so historical Order.items refs
  /// stay intact. Cleared if the item later reappears in a sync.
  posDeletedAt DateTime?

  modifierGroups MenuItemModifierGroup[]

  @@index([tenantId, isAvailable])
  @@index([tenantId, category])
  @@index([categoryId])
}

/// First-class grouping for MenuItems. A tenant may have one or more categories;
/// items link via `MenuItem.categoryId`. Name is unique per tenant.
/// `category` string on MenuItem is kept in sync for POS push/pull.
model MenuCategory {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  sortOrder     Int      @default(0)
  isAvailable   Boolean  @default(true)
  posCategoryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items MenuItem[]

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
}

model MenuItemModifierGroup {
  id            String   @id @default(uuid())
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String
  selectionType String   @default("SINGLE")
  required      Boolean  @default(false)
  minSelections Int      @default(0)
  maxSelections Int      @default(1)
  posGroupId    String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  modifiers MenuItemModifier[]

  @@index([menuItemId])
}

model MenuItemModifier {
  id            String                @id @default(uuid())
  groupId       String
  group         MenuItemModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name          String
  priceAdjust   Decimal               @default(0) @db.Decimal(10, 2)
  isDefault     Boolean               @default(false)
  posModifierId String?
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([groupId])
}

model UsageLog {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      UsageType
  metadata  Json?
  billedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@index([tenantId, type, createdAt])
}

model Contact {
  id               String        @id @default(cuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  phone            String
  name             String?
  email            String?
  nameSearchHash   String? // HMAC of lowercased name for SQL-level search on encrypted field
  emailSearchHash  String? // HMAC of lowercased email for SQL-level search on encrypted field
  notes            String? // kept for backward compat; use contactNotes for new entries
  status           ContactStatus @default(LEAD)
  tags             String[]      @default([])
  totalOrders      Int           @default(0)
  totalSpent       Int           @default(0) // in cents
  lastContactAt    DateTime?
  stripeCustomerId String?
  lastOrderId      String?
  lastOrderAt      DateTime?
  suppressed       Boolean       @default(false)
  loyaltyPoints    Int           @default(0)
  preferredLanguage String?      // BCP-47 tag like "en", "es", "tl"; null = auto-detect
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  contactNotes ContactNote[]
  missedCalls  MissedCall[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, updatedAt])
  @@index([tenantId, nameSearchHash])
  @@index([tenantId, emailSearchHash])
}

model PosSyncLog {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       String
  direction      String // "pull" or "push"
  totalItems     Int       @default(0)
  newItems       Int       @default(0)
  updatedItems   Int       @default(0)
  unchangedItems Int       @default(0)
  errors         Int       @default(0)
  errorDetail    Json?
  status         String    @default("running") // "running" | "completed" | "failed"
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([tenantId, startedAt])
}

model ReplyTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label     String
  body      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([tenantId, contactId])
}

enum TaskSource {
  VOICEMAIL
  CONVERSATION
  ORDER
  MEETING
  RAPID_REDIAL
  MANUAL
}

enum TaskPriority {
  URGENT
  HIGH
  NORMAL
}

enum TaskStatus {
  OPEN
  SNOOZED
  DONE
  DISMISSED
}

model Task {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String?      @db.Text
  source      TaskSource
  priority    TaskPriority @default(NORMAL)
  status      TaskStatus   @default(OPEN)

  missedCallId   String?
  conversationId String?
  orderId        String?
  meetingId      String?

  callerPhone String?

  snoozedUntil DateTime?
  completedAt  DateTime?
  completedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status, priority])
  @@index([tenantId, snoozedUntil])
  @@index([missedCallId])
  @@index([orderId])
  @@index([meetingId])
  @@index([conversationId])
}

// ── TCPA Consent + Industry Templates ───────────────────────────────────────

model IndustryTemplate {
  id                    String   @id @default(uuid())
  industryKey           String   @unique
  industryLabel         String
  consentMessageDefault String   @db.Text
  followupOpenerDefault String   @db.Text
  voiceGreetingDefault  String?  @db.Text
  aiSystemPrompt        String   @db.Text
  capabilityList        String[] @default([])
  escalationKeywords    String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SmsConsentRequest {
  id                String        @id @default(uuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone       String
  twilioNumber      String
  status            ConsentStatus @default(PENDING)
  consentMessageSid String?
  replyBody         String?
  consentedAt       DateTime?
  declinedAt        DateTime?
  expiresAt         DateTime
  repromptSent      Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId, callerPhone, status])
  @@index([tenantId, status])
}

model SmsSuppression {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone  String
  reason       String   @default("opt_out")
  suppressedAt DateTime @default(now())
  /// Inbound Turn whose handler decided to suppress this caller. Nullable,
  /// no FK — suppression rows must survive Turn retention.
  causingTurnId String?

  @@unique([tenantId, callerPhone])
}

model ConsentAuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  callerPhone String
  eventType   String
  eventData   Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, callerPhone])
  @@index([tenantId, createdAt])
}

model EscalationEvent {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone    String
  conversationId String?
  triggerKeyword String
  messageBody    String   @db.Text
  notifiedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
}

/// Idempotency log for provider webhook events. One row per provider event
/// id after it's been handled; subsequent deliveries short-circuit without
/// re-running side effects. Used to protect against Stripe replay + manual
/// "Resend" from the Dashboard.
model WebhookEventLog {
  id          String   @id                      // provider event id (e.g. "evt_1Abc...")
  provider    String                             // 'stripe' | 'calcom' | ...
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

/// Per-call AI token usage. One row per Claude / MiniMax / OpenAI request
/// so we can bill tenants by real usage and debug cost spikes.
model AiUsageLog {
  id           String   @id @default(uuid())
  tenantId     String
  provider     String   // 'claude' | 'minimax' | 'openai'
  model        String
  purpose      String   // 'order_agent' | 'intent_classifier' | 'fallback_chat' | 'tts' | ...
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  latencyMs    Int?
  success      Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([provider, createdAt])
}

// ───────────────────────────── Turn Record ─────────────────────────────
// One Turn = one inbound-SMS -> outcome cycle. Immutable audit row that
// captures the full decision trail so "why did caller +1… get (no reply)"
// is a single SELECT, not a log archaeology expedition. Observation layer
// only — never on the request-serving hot path.

enum TurnDirection {
  INBOUND
  OUTBOUND_PROACTIVE
}

enum DecisionPhase {
  PRE_HANDLER
  FLOW
  POST_HANDLER
}

enum TurnOutcome {
  REPLIED
  DEFLECTED
  SUPPRESSED_COMPLIANCE
  SUPPRESSED_RATE_LIMIT
  SUPPRESSED_DUPLICATE
  HANDED_OFF_TO_HUMAN
  QUEUED_FOR_BUSINESS_HOURS
  ERROR_LLM_TIMEOUT
  ERROR_LLM_REFUSED
  ERROR_HANDLER_THREW
  ERROR_UNHANDLED
}

model Turn {
  id                   String        @id @default(cuid())
  tenantId             String
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone          String
  direction            TurnDirection @default(INBOUND)

  // Input snapshot
  inboundMessageSid    String?
  /// AES-256-GCM encrypted; same scheme as Conversation.messages.
  inboundBodyEncrypted String?       @db.Text
  inboundReceivedAt    DateTime
  /// Tenant.config snapshot at turn-time so replays survive config drift.
  tenantConfigSnapshot Json
  /// { suppressed, preferredLanguage, callerStateFlowStep, ... }
  contactStateSnapshot Json?

  decisions            Decision[]

  // Outcome
  outcome              TurnOutcome
  outcomeReason        String?
  /// Null for any SUPPRESSED_* or ERROR_* outcome.
  replyBodyEncrypted   String?       @db.Text
  replyMessageSid      String?

  // Performance
  durationMs           Int
  llmCalled            Boolean       @default(false)
  llmLatencyMs         Int?

  createdAt            DateTime      @default(now())

  @@index([tenantId, callerPhone, createdAt])
  @@index([tenantId, outcome, createdAt])
  @@index([createdAt])
}

model Decision {
  id         String        @id @default(cuid())
  turnId     String
  turn       Turn          @relation(fields: [turnId], references: [id], onDelete: Cascade)

  /// 0-based position in the handler chain.
  sequence   Int
  handler    String
  phase      DecisionPhase
  /// Handler-specific, e.g. "suppressed_silent", "hit", "miss".
  outcome    String
  reason     String?
  evidence   Json?
  durationMs Int

  @@index([turnId, sequence])
  @@index([handler, outcome])
}
