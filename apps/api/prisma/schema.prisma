generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BusinessType {
  RESTAURANT
  FOOD_TRUCK
  SERVICE
  CONSULTANT
  MEDICAL
  RETAIL
  OTHER
}

enum Plan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum FlowType {
  ORDER
  MEETING
  INQUIRY
  CUSTOM
  FALLBACK
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum UsageType {
  SMS_SENT
  AI_CALL
  CALL_WEBHOOK
  SQUARE_ORDER
  POS_ORDER
}

enum ConsentStatus {
  PENDING
  CONSENTED
  DECLINED
  EXPIRED
}

enum PosProviderType {
  square
  clover
  toast
  shopify
}

enum HandoffStatus {
  AI
  HUMAN
}

enum ContactStatus {
  LEAD
  CUSTOMER
  VIP
  INACTIVE
}

enum CommissionStatus {
  PENDING
  PAID
  VOID
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum AgencyApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tenant {
  id                    String           @id @default(uuid())
  name                  String
  slug                  String?          @unique // URL-safe public identifier for menu page (ringbacksms.com/m/{slug})
  businessType          BusinessType
  plan                  Plan             @default(STARTER)
  twilioSubAccountSid   String?          @unique
  twilioAuthToken       String? // AES-256-GCM encrypted
  twilioPhoneNumber     String?          @unique
  twilioPhoneNumberSid  String?          @unique
  stripeCustomerId      String?          @unique
  stripeSubscriptionId  String?          @unique
  clerkOrgId            String?          @unique
  squareAccessToken     String? // AES-256-GCM encrypted
  squareRefreshToken    String? // AES-256-GCM encrypted
  squareLocationId      String?
  squareMerchantId      String?
  squareTokenExpiresAt  DateTime?
  // Provider-agnostic POS fields
  posProvider           PosProviderType?
  posAccessToken        String? // AES-256-GCM encrypted
  posRefreshToken       String? // AES-256-GCM encrypted
  posTokenExpiresAt     DateTime?
  posLocationId         String?
  posMerchantId         String?
  posRaw                Json? // provider-specific metadata
  isActive              Boolean          @default(true)
  agencyId              String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  agency             Agency?             @relation(fields: [agencyId], references: [id])
  config             TenantConfig?
  flows              Flow[]
  missedCalls        MissedCall[]
  conversations      Conversation[]
  orders             Order[]
  meetings           Meeting[]
  menuItems          MenuItem[]
  usageLogs          UsageLog[]
  contacts           Contact[]
  syncLogs           PosSyncLog[]
  replyTemplates     ReplyTemplate[]
  tasks              Task[]
  foodTruckSchedule  FoodTruckSchedule[]
  smsConsentRequests SmsConsentRequest[]
  smsSuppressions    SmsSuppression[]
  escalationEvents   EscalationEvent[]
  commissions        CommissionLedger[]

  @@index([twilioPhoneNumber])
  @@index([clerkOrgId])
  @@index([agencyId])
}

model Agency {
  id                     String   @id @default(uuid())
  clerkUserId            String   @unique
  name                   String?
  defaultRevSharePct     Decimal  @default(20) @db.Decimal(5, 2)
  stripeConnectAccountId String?  @unique
  stripeConnectOnboarded Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenants     Tenant[]
  commissions CommissionLedger[]
  payouts     Payout[]
}

model CommissionLedger {
  id                    String           @id @default(uuid())
  agencyId              String
  tenantId              String
  stripeInvoiceId       String           @unique
  invoiceAmountCents    Int
  commissionPct         Decimal          @db.Decimal(5, 2)
  commissionAmountCents Int
  currency              String           @default("usd")
  status                CommissionStatus @default(PENDING)
  payoutId              String?
  accruedAt             DateTime         @default(now())
  paidAt                DateTime?

  agency Agency  @relation(fields: [agencyId], references: [id])
  tenant Tenant  @relation(fields: [tenantId], references: [id])
  payout Payout? @relation(fields: [payoutId], references: [id])

  @@index([agencyId, status])
  @@index([tenantId])
}

model Payout {
  id               String       @id @default(uuid())
  agencyId         String
  amountCents      Int
  currency         String       @default("usd")
  stripeTransferId String?      @unique
  status           PayoutStatus @default(PENDING)
  periodStart      DateTime
  periodEnd        DateTime
  failureReason    String?
  createdAt        DateTime     @default(now())
  paidAt           DateTime?

  agency      Agency             @relation(fields: [agencyId], references: [id])
  commissions CommissionLedger[]

  @@index([agencyId, status])
}

model AgencyApplication {
  id          String                  @id @default(uuid())
  clerkUserId String                  @unique
  email       String
  fullName    String
  companyName String?
  website     String?
  pitch       String                  @db.Text
  status      AgencyApplicationStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?                 @db.Text
  createdAt   DateTime                @default(now())

  @@index([status])
}

model FoodTruckSchedule {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek    Int // 0=Sun..6=Sat
  locationName String?
  address      String
  openTime     String // "HH:mm"
  closeTime    String // "HH:mm"
  note         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
}

model TenantConfig {
  id                             String    @id @default(uuid())
  tenantId                       String    @unique
  tenant                         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  greeting                       String    @db.Text
  greetingAfterHours             String?   @db.Text
  greetingRapidRedial            String?   @db.Text
  greetingReturning              String?   @db.Text
  voiceGreeting                  String?   @db.Text
  voiceGreetingAfterHours        String?   @db.Text
  voiceGreetingRapidRedial       String?   @db.Text
  voiceGreetingReturning         String?   @db.Text
  voiceAudioUrl                  String?   // public URL for default greeting audio
  voiceAudioUrlAfterHours        String?   // public URL for after-hours greeting audio
  voiceAudioUrlRapidRedial       String?   // public URL for rapid-redial greeting audio
  voiceAudioUrlReturning         String?   // public URL for returning greeting audio
  voiceType                      String    @default("nova")
  timezone                       String    @default("America/Chicago")
  businessHoursStart             String    @default("11:00")
  businessHoursEnd               String    @default("20:00")
  businessDays                   Int[]
  businessSchedule               Json? // per-day hours: { "0": { "open": "11:00", "close": "19:30" }, ... }
  closedDates                    String[]  @default([]) // ISO date strings: ["2026-12-25"]
  aiPersonality                  String?   @db.Text
  calcomLink                     String?
  slackWebhook                   String?
  ownerEmail                     String?
  ownerPhone                     String?
  businessAddress                String?
  websiteUrl                     String?
  websiteContext                 String?   @db.Text // AI-extracted business context from website
  squareSyncEnabled              Boolean   @default(false)
  squareAutoSync                 Boolean   @default(false)
  posSyncEnabled                 Boolean   @default(false)
  posAutoSync                    Boolean   @default(false)
  requirePayment                 Boolean   @default(false)
  dashboardConfirmTaskCompletion Boolean   @default(true)
  dailyDigestEnabled             Boolean   @default(true)
  dailyDigestHour                Int       @default(8)
  // Prep time (restaurants & food trucks)
  defaultPrepTimeMinutes         Int? // null = feature unused
  largeOrderThresholdItems       Int? // null = no large-order rule
  largeOrderExtraMinutes         Int? // null = no large-order rule
  prepTimeOverrides              Json? // Array<{ dayOfWeek, start, end, extraMinutes, label? }>
  ordersAcceptingEnabled         Boolean   @default(true)
  aiOrderAgentEnabled            Boolean   @default(false) // per-tenant rollout of the AI-native ORDER flow (items 1-7)
  acceptClosedHourOrders         Boolean   @default(true)  // when true, bot schedules orders for next open slot even when currently closed
  minutesPerQueuedOrder          Int       @default(4)     // added to ETA for every order currently CONFIRMED or PREPARING
  salesTaxRate                   Decimal?  @db.Decimal(5, 4) // e.g. 0.0825 for 8.25%. Null = no tax applied.
  passStripeFeesToCustomer       Boolean   @default(false) // when true, add 2.9% + $0.30 processing fee as a line item on the checkout
  // cal.com integration (OAuth 2.0 authorization code)
  calcomAccessToken              String? // AES-256-GCM encrypted
  calcomRefreshToken             String? // AES-256-GCM encrypted
  calcomTokenExpiresAt           DateTime?
  calcomUserId                   Int?
  calcomUserEmail                String?
  calcomEventTypeId              Int?
  calcomEventTypeSlug            String?
  // Industry template + consent
  industryTemplateKey            String?
  consentMessage                 String?   @db.Text
  followupOpener                 String?   @db.Text
  customAiInstructions           String?   @db.Text
  customEscalationKeywords       String[]  @default([])
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
}

model Flow {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      FlowType
  isEnabled Boolean  @default(true)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type])
  @@index([tenantId, isEnabled])
}

model MissedCall {
  id                  String    @id @default(uuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone         String
  twilioCallSid       String    @unique
  occurredAt          DateTime
  smsSent             Boolean   @default(false)
  voicemailUrl        String?
  voicemailDuration   Int?
  voicemailReceivedAt DateTime?
  voicemailTranscript String?   @db.Text
  voicemailSummary    String?   @db.Text
  voicemailIntent     String?
  voicemailHandledAt  DateTime?
  transcriptionStatus String?
  firstReplyAt        DateTime?
  ownerRespondedAt    DateTime?
  contactId           String?
  contact             Contact?  @relation(fields: [contactId], references: [id])
  callerTier          String?
  createdAt           DateTime  @default(now())

  conversations Conversation[]

  @@index([tenantId, callerPhone])
  @@index([tenantId, occurredAt])
  @@index([contactId])
}

model Conversation {
  id            String        @id @default(uuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone   String
  missedCallId  String?
  missedCall    MissedCall?   @relation(fields: [missedCallId], references: [id])
  messages      Json          @default("[]")
  flowType      FlowType?
  handoffStatus HandoffStatus @default(AI)
  handoffAt     DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orders   Order[]
  meetings Meeting[]

  @@index([tenantId, callerPhone])
  @@index([tenantId, isActive])
}

model Order {
  id                 String       @id @default(uuid())
  tenantId           String
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId     String
  conversation       Conversation @relation(fields: [conversationId], references: [id])
  callerPhone        String
  orderNumber        String       @unique
  status             OrderStatus  @default(PENDING)
  items              Json
  subtotal           Decimal?     @db.Decimal(10, 2) // items-only subtotal before tax/fee
  taxAmount          Decimal?     @db.Decimal(10, 2) // sales tax applied
  feeAmount          Decimal?     @db.Decimal(10, 2) // processing fee passed to customer (if enabled)
  total              Decimal      @db.Decimal(10, 2) // final amount customer pays (subtotal + tax + fee)
  pickupTime         String?
  estimatedReadyTime DateTime?
  notes              String?      @db.Text
  squareOrderId      String?
  squarePaymentId    String?
  posOrderId         String?
  posPaymentId       String?
  stripePaymentId    String?
  stripePaymentUrl   String?
  paymentStatus      String?      @default("UNPAID")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, callerPhone])
}

model Meeting {
  id               String        @id @default(uuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId   String
  conversation     Conversation  @relation(fields: [conversationId], references: [id])
  callerPhone      String
  calcomBookingId  String?
  calcomBookingUid String?
  scheduledAt      DateTime?
  status           MeetingStatus @default(PENDING)
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, callerPhone])
}

model MenuItem {
  id                String    @id @default(uuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  description       String?   @db.Text
  price             Decimal   @db.Decimal(10, 2)
  category          String?
  imageUrl          String?
  isAvailable       Boolean   @default(true)
  duration          Int?
  requiresBooking   Boolean   @default(false)
  squareCatalogId   String?
  squareVariationId String?
  lastSyncedAt      DateTime?
  posCatalogId      String?
  posVariationId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  modifierGroups MenuItemModifierGroup[]

  @@index([tenantId, isAvailable])
  @@index([tenantId, category])
}

model MenuItemModifierGroup {
  id            String   @id @default(uuid())
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String
  selectionType String   @default("SINGLE")
  required      Boolean  @default(false)
  minSelections Int      @default(0)
  maxSelections Int      @default(1)
  posGroupId    String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  modifiers MenuItemModifier[]

  @@index([menuItemId])
}

model MenuItemModifier {
  id            String                @id @default(uuid())
  groupId       String
  group         MenuItemModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name          String
  priceAdjust   Decimal               @default(0) @db.Decimal(10, 2)
  isDefault     Boolean               @default(false)
  posModifierId String?
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([groupId])
}

model UsageLog {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      UsageType
  metadata  Json?
  billedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@index([tenantId, type, createdAt])
}

model Contact {
  id               String        @id @default(cuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  phone            String
  name             String?
  email            String?
  nameSearchHash   String? // HMAC of lowercased name for SQL-level search on encrypted field
  emailSearchHash  String? // HMAC of lowercased email for SQL-level search on encrypted field
  notes            String? // kept for backward compat; use contactNotes for new entries
  status           ContactStatus @default(LEAD)
  tags             String[]      @default([])
  totalOrders      Int           @default(0)
  totalSpent       Int           @default(0) // in cents
  lastContactAt    DateTime?
  stripeCustomerId String?
  lastOrderId      String?
  lastOrderAt      DateTime?
  suppressed       Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  contactNotes ContactNote[]
  missedCalls  MissedCall[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, updatedAt])
  @@index([tenantId, nameSearchHash])
  @@index([tenantId, emailSearchHash])
}

model PosSyncLog {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       String
  direction      String // "pull" or "push"
  totalItems     Int       @default(0)
  newItems       Int       @default(0)
  updatedItems   Int       @default(0)
  unchangedItems Int       @default(0)
  errors         Int       @default(0)
  errorDetail    Json?
  status         String    @default("running") // "running" | "completed" | "failed"
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([tenantId, startedAt])
}

model ReplyTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label     String
  body      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([tenantId, contactId])
}

enum TaskSource {
  VOICEMAIL
  CONVERSATION
  ORDER
  MEETING
  RAPID_REDIAL
  MANUAL
}

enum TaskPriority {
  URGENT
  HIGH
  NORMAL
}

enum TaskStatus {
  OPEN
  SNOOZED
  DONE
  DISMISSED
}

model Task {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String?      @db.Text
  source      TaskSource
  priority    TaskPriority @default(NORMAL)
  status      TaskStatus   @default(OPEN)

  missedCallId   String?
  conversationId String?
  orderId        String?
  meetingId      String?

  callerPhone String?

  snoozedUntil DateTime?
  completedAt  DateTime?
  completedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status, priority])
  @@index([tenantId, snoozedUntil])
  @@index([missedCallId])
  @@index([orderId])
  @@index([meetingId])
  @@index([conversationId])
}

// ── TCPA Consent + Industry Templates ───────────────────────────────────────

model IndustryTemplate {
  id                    String   @id @default(uuid())
  industryKey           String   @unique
  industryLabel         String
  consentMessageDefault String   @db.Text
  followupOpenerDefault String   @db.Text
  voiceGreetingDefault  String?  @db.Text
  aiSystemPrompt        String   @db.Text
  capabilityList        String[] @default([])
  escalationKeywords    String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SmsConsentRequest {
  id                String        @id @default(uuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone       String
  twilioNumber      String
  status            ConsentStatus @default(PENDING)
  consentMessageSid String?
  replyBody         String?
  consentedAt       DateTime?
  declinedAt        DateTime?
  expiresAt         DateTime
  repromptSent      Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId, callerPhone, status])
  @@index([tenantId, status])
}

model SmsSuppression {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone  String
  reason       String   @default("opt_out")
  suppressedAt DateTime @default(now())

  @@unique([tenantId, callerPhone])
}

model ConsentAuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  callerPhone String
  eventType   String
  eventData   Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, callerPhone])
  @@index([tenantId, createdAt])
}

model EscalationEvent {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone    String
  conversationId String?
  triggerKeyword String
  messageBody    String   @db.Text
  notifiedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
}

/// Per-call AI token usage. One row per Claude / MiniMax / OpenAI request
/// so we can bill tenants by real usage and debug cost spikes.
model AiUsageLog {
  id           String   @id @default(uuid())
  tenantId     String
  provider     String   // 'claude' | 'minimax' | 'openai'
  model        String
  purpose      String   // 'order_agent' | 'intent_classifier' | 'fallback_chat' | 'tts' | ...
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  latencyMs    Int?
  success      Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([provider, createdAt])
}
