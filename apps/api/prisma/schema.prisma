generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BusinessType {
  RESTAURANT
  SERVICE
  CONSULTANT
  MEDICAL
  RETAIL
  OTHER
}

enum Plan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum FlowType {
  ORDER
  MEETING
  CUSTOM
  FALLBACK
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum UsageType {
  SMS_SENT
  AI_CALL
  CALL_WEBHOOK
  SQUARE_ORDER
  POS_ORDER
}

enum PosProviderType {
  square
  clover
  toast
  shopify
}

enum ContactStatus {
  LEAD
  CUSTOMER
  VIP
  INACTIVE
}

model Tenant {
  id                    String       @id @default(uuid())
  name                  String
  businessType          BusinessType
  plan                  Plan         @default(STARTER)
  twilioSubAccountSid   String?      @unique
  twilioAuthToken       String?      // AES-256-GCM encrypted
  twilioPhoneNumber     String?      @unique
  stripeCustomerId      String?      @unique
  stripeSubscriptionId  String?      @unique
  clerkOrgId            String?      @unique
  squareAccessToken     String?      // AES-256-GCM encrypted
  squareRefreshToken    String?      // AES-256-GCM encrypted
  squareLocationId      String?
  squareMerchantId      String?
  squareTokenExpiresAt  DateTime?
  // Provider-agnostic POS fields
  posProvider          PosProviderType?
  posAccessToken       String?      // AES-256-GCM encrypted
  posRefreshToken      String?      // AES-256-GCM encrypted
  posTokenExpiresAt    DateTime?
  posLocationId        String?
  posMerchantId        String?
  posRaw               Json?        // provider-specific metadata
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  config        TenantConfig?
  flows         Flow[]
  missedCalls   MissedCall[]
  conversations Conversation[]
  orders        Order[]
  meetings      Meeting[]
  menuItems     MenuItem[]
  usageLogs     UsageLog[]
  contacts      Contact[]

  @@index([twilioPhoneNumber])
  @@index([clerkOrgId])
}

model TenantConfig {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  greeting            String   @db.Text
  timezone            String   @default("America/Chicago")
  businessHoursStart  String   @default("11:00")
  businessHoursEnd    String   @default("20:00")
  businessDays        Int[]
  aiPersonality       String?  @db.Text
  calcomLink          String?
  slackWebhook        String?
  ownerEmail          String?
  ownerPhone          String?
  squareSyncEnabled   Boolean  @default(false)
  squareAutoSync      Boolean  @default(false)
  posSyncEnabled      Boolean  @default(false)
  posAutoSync         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Flow {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      FlowType
  isEnabled Boolean  @default(true)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type])
  @@index([tenantId, isEnabled])
}

model MissedCall {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone    String
  twilioCallSid  String   @unique
  occurredAt     DateTime
  smsSent        Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversations Conversation[]

  @@index([tenantId, callerPhone])
  @@index([tenantId, occurredAt])
}

model Conversation {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerPhone  String
  missedCallId String?
  missedCall   MissedCall? @relation(fields: [missedCallId], references: [id])
  messages     Json      @default("[]")
  flowType     FlowType?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders   Order[]
  meetings Meeting[]

  @@index([tenantId, callerPhone])
  @@index([tenantId, isActive])
}

model Order {
  id             String      @id @default(uuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  callerPhone    String
  orderNumber    String      @unique
  status         OrderStatus @default(PENDING)
  items          Json
  total          Decimal     @db.Decimal(10, 2)
  pickupTime     String?
  notes          String?     @db.Text
  squareOrderId  String?
  squarePaymentId String?
  posOrderId          String?
  posPaymentId        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, callerPhone])
}

model Meeting {
  id               String        @id @default(uuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId   String
  conversation     Conversation  @relation(fields: [conversationId], references: [id])
  callerPhone      String
  calcomBookingId  String?
  calcomBookingUid String?
  scheduledAt      DateTime?
  status           MeetingStatus @default(PENDING)
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, callerPhone])
}

model MenuItem {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  description      String?  @db.Text
  price            Decimal  @db.Decimal(10, 2)
  category         String?
  isAvailable      Boolean  @default(true)
  squareCatalogId  String?
  squareVariationId String?
  lastSyncedAt     DateTime?
  posCatalogId        String?
  posVariationId      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, isAvailable])
  @@index([tenantId, category])
}

model UsageLog {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      UsageType
  metadata  Json?
  billedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@index([tenantId, type, createdAt])
}

model Contact {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  phone         String
  name          String?
  email         String?
  notes         String?       // kept for backward compat; use contactNotes for new entries
  status        ContactStatus @default(LEAD)
  tags          String[]      @default([])
  totalOrders   Int           @default(0)
  totalSpent    Int           @default(0)  // in cents
  lastContactAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contactNotes  ContactNote[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, status])
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([tenantId, contactId])
}
